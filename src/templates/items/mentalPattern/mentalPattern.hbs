{{#> "systems/animabf/templates/items/base/base-sheet.hbs"}}
  <div class="item-sheet-body">
    <div class="item-field"><label>Nombre</label><input type="text" name="name" value="{{item.name}}" /></div>
    <div class="item-row">
      <div class="item-field"><label>Coste</label><input type="number" name="system.cost.value" value="{{system.cost.value}}" /></div>
      <div class="item-field"><label>Coste 2</label><input type="number" name="system.cost2.value" value="{{system.cost2.value}}" /></div>
      <div class="item-field"><label>Opuesto</label><input type="text" name="system.opposite.value" value="{{system.opposite.value}}" /></div>
    </div>
    <div class="item-field"><label>Bonificadores</label><textarea name="system.bonus.value" rows="2">{{system.bonus.value}}</textarea></div>
    <div class="item-field"><label>Penalizadores</label><textarea name="system.penalty.value" rows="2">{{system.penalty.value}}</textarea></div>
    <div class="item-field"><label>Descripción</label><textarea name="system.description.value" rows="2">{{system.description.value}}</textarea></div>
  </div>
{{/"systems/animabf/templates/items/base/base-sheet.hbs"}}
